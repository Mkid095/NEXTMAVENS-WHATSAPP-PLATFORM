    "test:rls": "tsx src/test/rls.integration.test.ts",
    "setup": "node setup.mjs",
    "lint": "tsc --noEmit"
  },
  "dependencies": {
    "@prisma/client": "^6.4.1",
    "fastify": "^4.28.1",
    "@fastify/cors": "^8.5.0",
