    "@fastify/rate-limit": "^8.0.3",
    "@fastify/raw-body": "^4.2.0",
    "jsonwebtoken": "^9.0.2",
    "socket.io": "^4.8.1",
    "@socket.io/redis-adapter": "^8.3.0",
    "redis": "^4.7.0",
    "bullmq": "^5.13.0"
  },
  "devDependencies": {
    "prisma": "^6.4.1",
    "tsx": "^4.19.2",
    "typescript": "~5.8.2",
