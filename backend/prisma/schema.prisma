// Prisma schema for NEXTMAVENS WhatsApp Evolution API Platform
// Phase 1, Step 1: Enterprise-Grade Foundation with RLS

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ┌─────────────────────────────────────────────────────────────┐
// │ Core Multi-Tenancy Models                                  │
// └─────────────────────────────────────────────────────────────┘

model Organization {
  id          String   @id @default(cuid())
  name        String   // "Acme Corp"
  slug        String   @unique // "acme-corp"
  email       String   // Billing/contact email
  taxRate     Float?   // Tax rate as percentage (e.g., 7.5 for 7.5%)
  taxName     String?  // Tax type: VAT, GST, Sales Tax, etc.
  taxId       String?  // Tax registration number (optional)
  plan        Plan     @default(FREE)
  // Payment method management
  paystackCustomerCode String? @unique // Paystack customer identifier
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Relations
  members      Member[]
  instances    WhatsAppInstance[]
  templates    WhatsAppTemplate[]
  agents       WhatsAppAgent[]
  assignments  WhatsAppAssignment[]
  webhooks     WebhookSubscription[]
  quotaUsages  QuotaUsage[]
  invoices     Invoice[]
  payments     Payment[]
  paymentMethods PaymentMethod[] // Customer payment methods
  auditLogs    AuditLog[]  // Audit logs for this org
  deadLetters  DeadLetterQueue[]  // DLQ entries for this org
  usageEvents  UsageEvent[]       // Usage-based billing events
  featureFlags OrganizationFeatureFlag[] // Feature flag overrides
  coupons      Coupon[]           // Coupon management for Step 9

  @@map("organizations")
  @@index([slug])
}

model Member {
  id        String   @id @default(cuid())
  userId    String
  orgId     String
  role      Role     // ORG_ADMIN, MANAGER, AGENT, VIEWER
  createdAt DateTime @default(now())

  // Relations
  user User      @relation(fields: [userId], references: [id])
  org Organization @relation(fields: [orgId], references: [id])

  @@unique([userId, orgId])
  @@map("members")
  @@index([orgId])
  @@index([userId])
}

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  password     String
  name         String?
  avatar       String?
  role         Role     // SUPER_ADMIN, ORG_ADMIN, MANAGER, AGENT, VIEWER, API_USER
  isActive     Boolean  @default(true)
  mfaEnabled   Boolean  @default(false)
  mfaSecret    String?  // encrypted TOTP secret
  lastLogin    DateTime?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  // Relations
  memberships Member[]
  agents      WhatsAppAgent[]  // Agent profiles for this user
  auditLogs   AuditLog[]       // Audit logs for actions by this user

  @@map("users")
  @@index([email])
}

enum Role {
  SUPER_ADMIN
  ORG_ADMIN
  MANAGER
  AGENT
  VIEWER
  API_USER
  SYSTEM // For system processes (webhooks, cron jobs)
}

enum Plan {
  FREE
  STARTER
  PRO
  ENTERPRISE
}

// ┌─────────────────────────────────────────────────────────────┐
// │ WhatsApp Instance Models                                   │
// └─────────────────────────────────────────────────────────────┘

model WhatsAppInstance {
  id                  String   @id @default(cuid())
  orgId               String
  name                String   // "Support Team"
  evolutionInstanceName String? @unique // Evolution API instance name (e.g., "main")
  phoneNumber         String   @unique // E.164 format: +1234567890
  qrCode              String?  // Base64 QR code image
  status              InstanceStatus @default(DISCONNECTED)
  token               String?  // Evolution API token
  webhookUrl          String?  // Customer's webhook endpoint
  isPrimary           Boolean  @default(false)
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt
  lastSeen            DateTime?
  heartbeatStatus     HeartbeatStatus? @default(UNKNOWN)

  // Relations
  org                 Organization    @relation(fields: [orgId], references: [id])
  messages            WhatsAppMessage[]
  chats               WhatsAppChat[]
  templates           WhatsAppTemplate[]
  agents              WhatsAppAgent[]  // Agents that can use this instance
  assignments         WhatsAppAssignment[]  // Assignments for chats on this instance
  webhooks            WebhookSubscription[]
  deadLetters         DeadLetterQueue[]  // DLQ entries for this instance

  @@map("whatsapp_instances")
  @@index([orgId])
  @@index([phoneNumber])
  @@index([status])
  @@index([heartbeatStatus])
  @@index([evolutionInstanceName])
}

enum InstanceStatus {
  DISCONNECTED
  CONNECTING
  CONNECTED
  RECONNECTING
  ERROR
}

enum HeartbeatStatus {
  UNKNOWN
  ONLINE
  OFFLINE
}

// ┌─────────────────────────────────────────────────────────────┐
// │ Messaging Models                                           │
// └─────────────────────────────────────────────────────────────┘

model WhatsAppMessage {
  id             String   @id @default(cuid())
  orgId          String
  instanceId     String
  chatId         String
  messageId      String   // WhatsApp message ID (from Evolution API)
  parentMessageId String? // For replies
  from           String   // E.164 phone number or "me"
  to             String   // E.164 phone number
  type           MessageType // text, image, document, audio, video, location, button, template
  content        Json?    // Text body or media info
  status         MessageStatus
  priority       Int       @default(0) // 0=normal, 1=high, -1=low
  quotedData     Json?     // Quoted message data
  metadata       Json?     // Additional metadata (legacy)
  // Delivery receipt timestamps
  sentAt         DateTime?
  deliveredAt    DateTime?
  readAt         DateTime?
  failedAt       DateTime?
  failureReason  String?   // Reason if status is FAILED/REJECTED
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  // Relations
  instance WhatsAppInstance @relation(fields: [instanceId], references: [id])
  chat     WhatsAppChat    @relation(fields: [chatId], references: [id])
  statusHistories MessageStatusHistory[]

  @@map("whatsapp_messages")
  @@index([orgId])
  @@index([instanceId])
  @@index([chatId])
  @@index([messageId])
  @@index([createdAt])
  @@index([status])
  @@index([from])
  @@index([to])
  @@index([sentAt])
  @@index([deliveredAt])
  @@index([readAt])
  @@unique([orgId, messageId])
}

// ┌─────────────────────────────────────────────────────────────┐
// │ Message Status History                                      │
// └─────────────────────────────────────────────────────────────┘

model MessageStatusHistory {
  id          String   @id @default(cuid())
  messageId   String
  status      MessageStatus
  changedAt   DateTime @default(now())
  changedBy   String?   // user ID or "system" for automated changes
  reason      String?   // "webhook", "admin", "queue", "dlq", "creation", etc.
  metadata    Json?     // Additional context (error details, retry count, etc.)

  // Relations
  message WhatsAppMessage @relation(fields: [messageId], references: [id])

  @@map("message_status_history")
  @@index([messageId])
  @@index([changedAt])
  @@index([messageId, changedAt])
}

enum MessageType {
  text
  image
  document
  audio
  video
  location
  button
  template
  reaction
}

enum MessageStatus {
  PENDING
  SENDING
  SENT
  DELIVERED
  READ
  FAILED
  REJECTED
  CANCELLED
}

model WhatsAppChat {
  id          String   @id @default(cuid())
  orgId       String
  instanceId  String
  chatId      String   // WhatsApp chat ID
  phone       String   // Customer's phone (E.164)
  name        String?  // Customer name
  avatar      String?
  lastMessageAt DateTime?
  unreadCount Int     @default(0)
  isGroup     Boolean  @default(false)
  isArchived  Boolean  @default(false)
  isPinned    Boolean  @default(false)
  metadata    Json?    // Custom fields
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Relations
  instance    WhatsAppInstance @relation(fields: [instanceId], references: [id])
  messages    WhatsAppMessage[]
  assignment  WhatsAppAssignment?  // Current assignment (one agent per chat)

  @@map("whatsapp_chats")
  @@index([orgId])
  @@index([instanceId])
  @@index([chatId])
  @@index([phone])
  @@index([lastMessageAt])
  @@unique([orgId, chatId])
}

// ┌─────────────────────────────────────────────────────────────┐
// │ Template Models                                            │
// └─────────────────────────────────────────────────────────────┘

model WhatsAppTemplate {
  id           String   @id @default(cuid())
  orgId        String
  instanceId   String?
  name         String
  language     String   @default("en")
  category     TemplateCategory
  status       TemplateStatus @default(DRAFT)
  components   Json     // Header, body, footer, buttons
  variables    String[] // ["name", "order_id"]
  sampleData   Json?
  mediaUrl     String?
  quality      Float?   // A/B test quality score
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  approvedAt   DateTime?
  rejectedAt   DateTime?
  rejectionReason String?

  // Relations
  org      Organization      @relation(fields: [orgId], references: [id])
  instance WhatsAppInstance? @relation(fields: [instanceId], references: [id])

  @@map("whatsapp_templates")
  @@index([orgId])
  @@index([instanceId])
  @@index([status])
  @@unique([orgId, name, language])
}

enum TemplateCategory {
  MARKETING
  TRANSACTIONAL
  UTILITY
}

enum TemplateStatus {
  DRAFT
  PENDING_SUBMISSION
  SUBMITTED
  APPROVED
  REJECTED
  PAUSED
}

// ┌─────────────────────────────────────────────────────────────┐
// │ Agent & Assignment Models                                  │
// └─────────────────────────────────────────────────────────────┘

model WhatsAppAgent {
  id        String   @id @default(cuid())
  orgId     String
  userId    String   // References User.id
  instanceId String? // Which WhatsApp instance this agent is assigned to (optional)
  isActive  Boolean  @default(true)
  maxChats  Int      @default(10)
  createdAt DateTime @default(now())

  // Relations
  org        Organization     @relation(fields: [orgId], references: [id])
  user       User             @relation(fields: [userId], references: [id])
  instance   WhatsAppInstance? @relation(fields: [instanceId], references: [id])
  assignments WhatsAppAssignment[]

  @@unique([userId, orgId])
  @@map("whatsapp_agents")
  @@index([orgId])
  @@index([userId])
  @@index([instanceId])
}

model WhatsAppAssignment {
  id         String   @id @default(cuid())
  orgId      String
  instanceId String   // The WhatsApp instance this chat belongs to
  chatId     String
  agentId    String
  assignedAt DateTime @default(now())
  assignedBy String?  // User ID who assigned

  // Relations
  org      Organization    @relation(fields: [orgId], references: [id])
  instance WhatsAppInstance @relation(fields: [instanceId], references: [id])
  chat     WhatsAppChat    @relation(fields: [chatId], references: [id])
  agent    WhatsAppAgent   @relation(fields: [agentId], references: [id])

  @@unique([chatId]) // One agent per chat
  @@map("whatsapp_assignments")
  @@index([orgId])
  @@index([instanceId])
  @@index([agentId])
  @@index([chatId])
}

// ┌─────────────────────────────────────────────────────────────┐
// │ Webhook Models                                             │
// └─────────────────────────────────────────────────────────────┘

model WebhookSubscription {
  id          String   @id @default(cuid())
  orgId       String
  instanceId  String
  eventType   String   // "message.sent", "message.delivered", etc.
  url         String   // Customer's webhook URL
  secret      String   // HMAC secret for verification
  isActive    Boolean  @default(true)
  retryCount  Int      @default(3)
  createdAt   DateTime @default(now())

  // Relations
  org       Organization    @relation(fields: [orgId], references: [id])
  instance  WhatsAppInstance @relation(fields: [instanceId], references: [id])
  deliveries WebhookDeliveryLog[]

  @@map("webhook_subscriptions")
  @@index([orgId])
  @@index([instanceId])
  @@unique([orgId, instanceId, eventType, url])
}

model WebhookDeliveryLog {
  id             String   @id @default(cuid())
  orgId          String
  subscriptionId String
  eventId        String   // Unique event ID for deduplication
  payload        Json
  status         WebhookDeliveryStatus
  attempts       Int      @default(0)
  lastAttemptAt  DateTime?
  errorMessage   String?
  nextRetryAt    DateTime?
  createdAt      DateTime @default(now())

  // Relations
  subscription WebhookSubscription @relation(fields: [subscriptionId], references: [id])

  @@map("webhook_delivery_logs")
  @@index([orgId])
  @@index([subscriptionId])
  @@index([eventId])
  @@index([status])
  @@index([nextRetryAt])
  @@unique([orgId, eventId])
}

enum WebhookDeliveryStatus {
  PENDING
  DELIVERED
  FAILED
  RETRYING
  DEAD
}

// ┌─────────────────────────────────────────────────────────────┐
// │ Dead Letter Queue (DLQ)                                     │
// └─────────────────────────────────────────────────────────────┘

model DeadLetterQueue {
  id            String   @id @default(cuid())
  orgId         String
  instanceId    String
  event         String   // Webhook event type (e.g., "message.sent")
  payload       Json     // Original webhook payload
  error         String   // Error message that caused failure
  retryCount    Int      @default(0)  // Number of retry attempts before death
  lastAttempted DateTime? // Timestamp of last retry attempt
  createdAt     DateTime @default(now())

  // Relations
  org      Organization    @relation(fields: [orgId], references: [id])
  instance WhatsAppInstance @relation(fields: [instanceId], references: [id])

  @@map("dead_letter_queues")
  @@index([orgId])
  @@index([instanceId])
  @@index([createdAt])
  @@index([orgId, createdAt])
}

// ┌─────────────────────────────────────────────────────────────┐
// │ Quota & Billing Models                                     │
// └─────────────────────────────────────────────────────────────┘

model QuotaUsage {
  id         String   @id @default(cuid())
  orgId      String
  metric     QuotaMetric // "messages_sent", "active_instances", "api_calls"
  value      BigInt
  period     QuotaPeriod // "hourly", "daily", "monthly"
  periodStart DateTime // Start of period (e.g., 2025-03-01 00:00:00)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  // Relations
  org Organization @relation(fields: [orgId], references: [id])

  @@unique([orgId, metric, period, periodStart])
  @@map("quota_usages")
  @@index([orgId])
  @@index([metric, period, periodStart])
}

enum QuotaMetric {
  messages_sent
  active_instances
  api_calls
  storage_usage
}

enum QuotaPeriod {
  hourly
  daily
  monthly
}

// ┌─────────────────────────────────────────────────────────────┐
// │ Billing Models                                             │
// └─────────────────────────────────────────────────────────────┘

model Invoice {
  id               String   @id @default(cuid())
  orgId            String
  stripeInvoiceId  String   @unique
  number           String   // Human-readable: INV-2025-001
  amount           Int      // Cents
  currency         String   @default("USD")
  status           InvoiceStatus
  periodStart      DateTime
  periodEnd        DateTime
  dueDate          DateTime
  paidAt           DateTime?
  pdfUrl           String?
  createdAt        DateTime @default(now())

  // Relations
  org    Organization    @relation(fields: [orgId], references: [id])
  items  InvoiceItem[]

  @@map("invoices")
  @@index([orgId])
  @@index([stripeInvoiceId])
  @@index([status])
}

enum InvoiceStatus {
  DRAFT
  OPEN
  PAID
  VOID
  UNCOLLECTIBLE
}

model InvoiceItem {
  id            String   @id @default(cuid())
  invoiceId     String
  invoice       Invoice  @relation(fields: [invoiceId], references: [id])
  orgId         String   // Denormalized for RLS performance
  description   String
  quantity      Int
  unitPriceCents Int
  totalCents    Int
  metadata      Json?

  @@map("invoice_items")
  @@index([invoiceId])
  @@index([orgId])
}

model Payment {
  id              String   @id @default(cuid())
  orgId           String
  stripePaymentId String   @unique
  invoiceId       String?
  amount          Int      // Cents
  currency        String   @default("USD")
  status          PaymentStatus
  methodType      String?  // "card", "bank_transfer"
  createdAt       DateTime @default(now())

  // Relations
  org Organization @relation(fields: [orgId], references: [id])

  @@map("payments")
  @@index([orgId])
  @@index([stripePaymentId])
}

// ┌─────────────────────────────────────────────────────────────┐
// │ Payment Methods (Customer Cards)                           │
// └─────────────────────────────────────────────────────────────┘

model PaymentMethod {
  id                String   @id @default(cuid())
  orgId             String
  authorizationCode String   // Reusable Paystack authorization code for this card
  last4             String   // Last 4 digits of card
  brand             String   // visa, mastercard, amex
  expMonth          Int
  expYear           Int
  isDefault         Boolean  @default(false)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  // Relations
  org Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)

  @@map("payment_methods")
  @@index([orgId])
  @@unique([orgId, authorizationCode]) // avoid duplicate cards per org
  @@index([isDefault])
}

enum PaymentStatus {
  SUCCEEDED
  FAILED
  PROCESSING
  REQUIRES_ACTION
  CANCELED
}

// ┌─────────────────────────────────────────────────────────────┐
// │ Audit & Compliance                                         │
// └─────────────────────────────────────────────────────────────┘

model AuditLog {
  id          String   @id @default(cuid())
  orgId       String?  // NULL for SUPER_ADMIN actions
  userId      String   // Who performed the action
  action      String   // "user.created", "template.deleted", "instance.disconnected"
  resource    String   // Type of resource affected
  resourceId  String?  // ID of affected resource
  changes     Json?    // Before/after values
  ipAddress   String?
  userAgent   String?
  createdAt   DateTime @default(now())

  // Relations
  org     Organization? @relation(fields: [orgId], references: [id])
  user    User          @relation(fields: [userId], references: [id])

  @@map("audit_logs")
  @@index([orgId])
  @@index([userId])
  @@index([action])
  @@index([createdAt])
  @@index([orgId, createdAt]) // For org-specific logs
}

// ┌─────────────────────────────────────────────────────────────┐
// │ Workflow Orchestration (Phase 3 Step 3)                     │
// └─────────────────────────────────────────────────────────────┘

enum WorkflowStatus {
  PENDING
  RUNNING
  COMPLETED
  FAILED
  CANCELLED
  COMPENSATING
  COMPENSATED
}

enum WorkflowStepStatus {
  PENDING
  RUNNING
  COMPLETED
  FAILED
  SKIPPED
  COMPENSATED
}

model WorkflowDefinition {
  id                String   @id @default(cuid())
  workflowId        String   @unique // e.g., "send-notification-with-followup"
  name              String
  description       String?
  version           Int      @default(1)
  stepsJson         Json     // Array of step definitions
  compensationJson  Json?    // Optional: compensation step definitions
  timeoutMs         Int?     // Default timeout for entire workflow (milliseconds)
  retryPolicyJson   Json?    // Default retry policy
  isActive          Boolean  @default(true)
  createdBy         String   // User ID (SUPER_ADMIN)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  // Relations
  instances WorkflowInstance[]

  @@map("workflow_definitions")
  @@index([workflowId])
  @@index([isActive])
}

model WorkflowInstance {
  id                  String   @id @default(cuid())
  instanceId          String   @unique
  definitionId        String
  definition          WorkflowDefinition @relation(fields: [definitionId], references: [id])
  status              WorkflowStatus
  currentStep         Int?     // 0-based index, null if completed/failed
  contextJson         Json     // Shared execution context
  startedAt           DateTime @default(now())
  completedAt         DateTime?
  failedAt            DateTime?
  failureReason       String?
  lastHeartbeatAt     DateTime?
  orgId               String   // For RLS and tenant isolation

  // Relations
  stepsHistory WorkflowStepHistory[]

  @@map("workflow_instances")
  @@index([definitionId])
  @@index([status])
  @@index([orgId])
  @@index([startedAt])
  @@unique([instanceId, orgId])
}

model WorkflowStepHistory {
  id                  String   @id @default(cuid())
  instanceId          String
  stepIndex           Int
  stepName            String?
  status              WorkflowStepStatus
  startedAt           DateTime @default(now())
  completedAt         DateTime?
  failedAt            DateTime?
  errorMessage        String?
  retryCount          Int      @default(0)
  inputJson           Json?
  outputJson          Json?
  metadata            Json?

  instance WorkflowInstance @relation(fields: [instanceId], references: [id], onDelete: Cascade)

  @@map("workflow_step_history")
  @@index([instanceId])
  @@index([stepIndex])
  @@index([startedAt])
  @@index([instanceId, stepIndex])
}

model UsageEvent {
  id         String   @id @default(cuid())
  orgId      String
  customerId String   // Customer identifier (defaults to orgId)
  meterName  String
  value      Float    // Usage quantity (can be integer or decimal depending on meter)
  recordedAt DateTime @default(now())
  metadata   Json?

  // Relations
  org Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)

  @@map("usage_events")
  @@index([orgId, meterName, recordedAt])
  @@index([customerId])
  @@index([meterName, recordedAt])
}

// ┌─────────────────────────────────────────────────────────────┐
// │ Feature Management Models (Phase 3 Step 8.5)                │
// └─────────────────────────────────────────────────────────────┘

model FeatureFlag {
  id          String   @id @default(cuid())
  key         String   @unique // e.g., "billing_enabled", "payments_enabled"
  name        String   // Human-readable name
  description String?  // Optional description
  enabled     Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Relations
  orgOverrides OrganizationFeatureFlag[]

  @@map("feature_flags")
  @@index([key])
  @@index([enabled])
}

model OrganizationFeatureFlag {
  id         String   @id @default(cuid())
  orgId      String
  featureKey String   // References FeatureFlag.key
  enabled    Boolean? // null = inherit from global, true = forced on, false = forced off
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  // Relations
  org        Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  feature    FeatureFlag  @relation(fields: [featureKey], references: [key], onDelete: Cascade)

  @@unique([orgId, featureKey])
  @@map("organization_feature_flags")
  @@index([orgId])
  @@index([featureKey])
  @@index([enabled])
}

// ┌─────────────────────────────────────────────────────────────┐
// │ Coupon & Discount Models (Phase 3 Step 9)                  │
// └─────────────────────────────────────────────────────────────┘

model Coupon {
  id                String   @id @default(cuid())
  code              String   @unique
  name              String
  description       String?
  discountType      String   // "percentage" | "fixed"
  discountValue     Float
  maxUses           Int?
  usedCount         Int      @default(0)
  perUserLimit      Int?
  minPurchaseAmount Float?
  validFrom         DateTime
  validTo           DateTime
  orgId             String
  createdBy         String
  isActive          Boolean  @default(true)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  // Relations
  org       Organization    @relation(fields: [orgId], references: [id], onDelete: Cascade)
  usage     CouponUsage[]
}

model CouponUsage {
  id       String   @id @default(cuid())
  couponId String
  orgId    String
  userId   String?
  usedAt   DateTime @default(now())
  orderId  String?

  coupon Coupon @relation(fields: [couponId], references: [id], onDelete: Cascade)

  @@unique([couponId, orgId, userId, orderId])
}
