# Database Configuration
DATABASE_URL="postgresql://flow:flow_research_secure_2026@localhost:5433/nextmavens_research?connection_limit=20&pool_timeout=10"

# For production, use:
# DATABASE_URL="postgresql://user:password@your-db-host:5432/nextmavens_platform"

# JWT Secrets (generate strong random secrets)
JWT_SECRET="your-super-secret-jwt-key-change-this-in-production-min-256-bits"
JWT_REFRESH_SECRET="your-refresh-secret-key-change-this-too-min-256-bits"
JWT_EXPIRY="15m"
JWT_REFRESH_EXPIRY="7d"

# Redis (for rate limiting, BullMQ, caching)
REDIS_URL="redis://localhost:6379"

# Evolution API
EVOLUTION_API_URL="http://localhost:3001"
EVOLUTION_API_KEY="your-evolution-api-key"
EVOLUTION_WEBHOOK_SECRET="your-evolution-webhook-secret-generate-with-openssl-rand-base64-32"

# Stripe (for billing)
STRIPE_SECRET_KEY="sk_test_xxx"
STRIPE_WEBHOOK_SECRET="whsec_xxx"

# Claude AI (for differentiator features)
ANTHROPIC_API_KEY="sk-ant-xxx"

# App Settings
NODE_ENV="development"
PORT="3000"
LOG_LEVEL="info"

# Message Retry & DLQ System (Phase 3 Step 1)
ENABLE_RETRY_DLQ="false"                  # Enable/disable retry and DLQ system (default: false)
MESSAGE_RETRY_MAX_ATTEMPTS="5"            # Max retry attempts before DLQ (default: 5)
MESSAGE_RETRY_BASE_DELAY_MS="1000"        # Base delay in ms for exponential backoff (default: 1000)
MESSAGE_RETRY_MAX_DELAY_MS="300000"       # Max retry delay in ms (default: 300000 = 5min)
MESSAGE_RETRY_JITTER="0.15"               # Jitter factor 0-1 (default: 0.15)
DLQ_RETENTION_DAYS="30"                   # How long to keep failed messages in DLQ (default: 30)
DLQ_STREAM_PREFIX="dlq:whatsapp"          # Redis stream key prefix for DLQ (default: dlq:whatsapp)

# Queue Configuration
QUEUE_CONCURRENCY="10"                    # Number of concurrent workers (default: 10)

# Workflow Orchestration (Phase 3 Step 3)
ENABLE_WORKFLOW_ORCHESTRATION="false"     # Enable/disable workflow orchestration system (default: false)
WORKFLOW_MAX_RETRIES="3"                  # Default max retries for workflow steps (default: 3)
WORKFLOW_BASE_RETRY_DELAY_MS="1000"       # Base retry delay in ms (default: 1000)
WORKFLOW_TIMEOUT_DEFAULT_MS="3600000"     # Default workflow timeout (1 hour)
