{
  "extends": "../tsconfig",
  "compilerOptions": {
    "moduleResolution": "node",
    "types": ["node"],
    "typeRoots": ["./node_modules/@types", "../node_modules/@types", "./src/types"],
    "lib": ["ES2022"],
    "noEmit": true,
    "skipLibCheck": true,
    "allowSyntheticDefaultImports": true,
    "esModuleInterop": true
  },
  "include": ["src"],
  "exclude": ["node_modules", "dist", "src/test"]
}