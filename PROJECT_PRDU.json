{
  "project": "WhatsApp Evolution API Management Portal",
  "version": "1.0",
  "date": "2026-03-03",
  "domain": "https://whatsapp.nextmavens.cloud",
  "overview": "Comprehensive management portal for Evolution API WhatsApp instances. Provides multi-tenant reseller capabilities, team management, real-time messaging, analytics, and full lifecycle management of WhatsApp business accounts.",

  "architecture": {
    "frontend": {
      "tech_stack": ["Vite 7", "React 19", "TypeScript 5.8", "Tailwind CSS 4", "React Query 5", "React Router 7"],
      "build_output": "dist/",
      "deployment": "/var/www/whatsapp-admin/ (nginx)",
      "api_base_url": "https://whatsappapi.nextmavens.cloud/api/v1"
    },
    "backend": {
      "tech_stack": ["Fastify 5", "TypeScript", "Prisma ORM", "PostgreSQL 15+", "Redis (BullMQ)", "WebSocket"],
      "location": "/home/ken/next-mavens-vps/",
      "services": {
        "api": "mavens-api (port 3000)",
        "realtime": "mavens-realtime (port 3003)",
        "webhook": "mavens-webhook (port 3004)",
        "cron": "scheduled jobs"
      },
      "database": "PostgreSQL with RLS (Row Level Security)"
    },
    "evolution_api_integration": {
      "base_url": "http://localhost:8080 (or configured via EVOLUTION_API_URL)",
      "authentication": "API key per instance",
      "webhook_secret": "EVOLUTION_WEBHOOK_SECRET env var",
      "features": ["Instance management", "QR code connection", "Message sending", "Group management", "Template messaging", "Real-time events via webhooks"]
    }
  },

  "roles_and_permissions": {
    "user_roles": [
      "SUPER_ADMIN - Full system access",
      "ORG_ADMIN - Organization management",
      "TEAM_AGENT - Customer support agents",
